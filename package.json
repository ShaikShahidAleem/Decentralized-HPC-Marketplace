{
  "name": "hpc-marketplace",
  "version": "1.0.0",
  "description": "Decentralized High-Performance Computing Marketplace Prototype",
  "main": "index.js",
  "scripts": {
    "compile": "hardhat compile",
    "test": "hardhat test",
    "node": "hardhat node --hostname 0.0.0.0",
    "deploy": "hardhat run scripts/deploy.js --network localhost",
    "deploy:local": "hardhat run scripts/deploy.js --network localhost",
    "demo": "hardhat run scripts/demo.js --network localhost",
    "provider": "node provider/index.js",
    "provider:multi": "node provider/multi-provider.js",
    "provider:remote": "node provider/index.js",
    "client": "npx http-server client -p 3000 -c-1"
  },
  "keywords": [
    "blockchain",
    "hpc",
    "marketplace",
    "decentralized",
    "ethereum"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "hardhat": "^2.19.0",
    "hardhat-contract-sizer": "^2.10.1",
    "solidity-coverage": "^0.8.17"
  },
  "dependencies": {
    "@openzeppelin/contracts": "^5.0.0",
    "dotenv": "^16.3.1",
    "ethers": "^6.9.0",
    "http-server": "^14.1.1"
  }
}